<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<StackPane maxHeight="-Infinity" maxWidth="-Infinity"
           minHeight="-Infinity" minWidth="-Infinity"
           prefHeight="400.0" prefWidth="600.0"
           fx:controller="com.dataingengjoer.monopoly.ui.controller.MenuController"
           xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
<children>
    <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0" spacing="40.0">
        <children>
            <VBox alignment="CENTER" prefHeight="94.0" prefWidth="601.0">
                <children>
                    <Label alignment="CENTER" text="Monopoly" textFill="#2cb257">
                        <font>
                            <Font name="Times New Roman Bold" size="48.0" />
                        </font>
                        <opaqueInsets>
                            <Insets />
                        </opaqueInsets>
                    </Label>
                    <Label alignment="CENTER" prefHeight="30.0" prefWidth="521.0" text="Where Streets Become Sovereignties and Fortune Favors the Astute">
                        <font>
                            <Font name="Calibri Bold" size="16.0" />
                        </font>
                        <opaqueInsets>
                            <Insets />
                        </opaqueInsets>
                    </Label>
                </children>
            </VBox>
            <Button mnemonicParsing="false" prefWidth="54.0" text="GAME" fx:id="startButton"/>
            <Button mnemonicParsing="false" text="SETTINGS" fx:id="settings"/>
        </children>
    </VBox>
</children>
</StackPane>
